{
	"name": "Capstone1_Backupfolder",
	"properties": {
		"linkedServiceName": {
			"referenceName": "LS_ADLS",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"filename": {
				"type": "string"
			},
			"foldername": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "DelimitedText",
		"typeProperties": {
			"location": {
				"type": "AzureBlobStorageLocation",
				"fileName": {
					"value": "@dataset().filename",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@dataset().foldername",
					"type": "Expression"
				},
				"container": "capstoneproject1"
			},
			"columnDelimiter": ",",
			"escapeChar": "\\",
			"firstRowAsHeader": true,
			"quoteChar": "\""
		},
		"schema": [
			{
				"name": "CustomerID",
				"type": "String"
			},
			{
				"name": "Name",
				"type": "String"
			},
			{
				"name": "City",
				"type": "String"
			},
			{
				"name": "Email",
				"type": "String"
			},
			{
				"name": "DOB",
				"type": "String"
			}
		]
	}
}